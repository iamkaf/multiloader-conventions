    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "license": "${license}",
    "environment": "*",
    "entrypoints": {
        "fabric-datagen": [
            "com.example.datagen.fabric.ExampleDatagen"
        ]
    },
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "fabric-api": "*",
        "minecraft": "${fabric_version_range}",
        "java": ">=${java_version}"
    }
}
